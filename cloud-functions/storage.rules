rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function userProfileDocument() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function tenantExists(tenantId) {
      return tenantId != 'DEFAULT' &&
             firestore.exists(/databases/(default)/documents/tenants/$(tenantId));
    }

    function bookingDocument(tenantId, bookingId) {
      return firestore.get(/databases/(default)/documents/tenants/$(tenantId)/bookings/$(bookingId));
    }

    function canAccessFieldPhoto(tenantId, bookingId) {
      let profile = userProfileDocument();
      let booking = bookingDocument(tenantId, bookingId);
      return tenantId != 'DEFAULT' &&
             profile != null &&
             booking != null &&
             profile.data.status == 'active' &&
             (profile.data.role == 'super-admin' ||
              (profile.data.tenantId == tenantId &&
               (profile.data.role == 'admin' ||
                (profile.data.role == 'employee' &&
                 'assignedEmployeeAuthUid' in booking.data &&
                 booking.data.assignedEmployeeAuthUid == request.auth.uid &&
                 booking.data.status in ['scheduled', 'completed'] &&
                 (!('isDeleted' in booking.data) || booking.data.isDeleted != true) &&
                 (!('isArchived' in booking.data) || booking.data.isArchived != true)))));
    }

    function canAccessBranding(tenantId) {
      let profile = userProfileDocument();
      return tenantExists(tenantId) &&
             profile != null &&
             profile.data.role == 'super-admin' &&
             profile.data.status == 'active';
    }

    function isAllowedPhase(phase) {
      return phase in ['before', 'after'];
    }

    function validPhotoObject(fileName) {
      return request.resource != null &&
             request.resource.size > 0 &&
             request.resource.size <= 10 * 1024 * 1024 &&
             ((request.resource.contentType == 'image/jpeg' && fileName.matches('^[A-Za-z0-9_-]+\\.jpg$')) ||
              (request.resource.contentType == 'image/png' && fileName.matches('^[A-Za-z0-9_-]+\\.png$')) ||
              (request.resource.contentType == 'image/webp' && fileName.matches('^[A-Za-z0-9_-]+\\.webp$')));
    }

    function validBrandingObject() {
      return request.resource != null &&
             request.resource.size > 0 &&
             request.resource.size <= 5 * 1024 * 1024 &&
             request.resource.contentType in [
               'image/jpeg',
               'image/png',
               'image/webp',
               'image/gif',
               'image/x-icon'
             ];
    }

    match /tenants/{tenantId}/bookings/{bookingId}/field-photos/{phase}/{fileName} {
      allow read: if isAllowedPhase(phase) &&
                     isAuthenticated() &&
                     canAccessFieldPhoto(tenantId, bookingId);
      allow create: if isAllowedPhase(phase) &&
                       isAuthenticated() &&
                       canAccessFieldPhoto(tenantId, bookingId) &&
                       resource == null &&
                       validPhotoObject(fileName);
      allow update, delete: if false;
    }

    // Company Settings is a mounted super-admin compatibility surface.
    match /tenants/{tenantId}/branding/{fileName} {
      allow read: if isAuthenticated() && canAccessBranding(tenantId);
      allow create: if isAuthenticated() &&
                       canAccessBranding(tenantId) &&
                       resource == null &&
                       validBrandingObject();
      allow update, delete: if false;
    }

    // Present in unmounted legacy code; these require a separate ownership/migration contract.
    match /tenants/{tenantId}/documents/{allPaths=**} {
      allow read, write: if false;
    }

    match /tenants/{tenantId}/signatures/{allPaths=**} {
      allow read, write: if false;
    }

    match /tenants/{tenantId}/photos/{allPaths=**} {
      allow read, write: if false;
    }

    match /tenants/{tenantId}/property_conditions/{allPaths=**} {
      allow read, write: if false;
    }

    match /tenants/{tenantId}/incidents/{allPaths=**} {
      allow read, write: if false;
    }

    match /jobPhotos/{allPaths=**} {
      allow read, write: if false;
    }

    match /{unknownPath=**} {
      allow read, write: if false;
    }
  }
}
