{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "test": "node --test",
    "test:rules": "npx firebase-tools@13.35.1 emulators:exec --only firestore --project demo-servicesos-rules \"node --test rules-tests/firestore.rules.js\"",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "cors": "^2.8.6",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "stripe": "^14.10.0"
  },
  "private": true,
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1"
  }
}
