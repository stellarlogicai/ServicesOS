rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function userProfileExists() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function tenantExists(tenantId) {
      return tenantId != 'DEFAULT' &&
             exists(/databases/$(database)/documents/tenants/$(tenantId));
    }

    function isSuperAdmin() {
      return userProfileExists() &&
             userProfile().role == 'super-admin' &&
             userProfile().status == 'active';
    }

    function isTenantAdmin(tenantId) {
      return tenantExists(tenantId) &&
             userProfileExists() &&
             userProfile().role == 'admin' &&
             userProfile().status == 'active' &&
             userProfile().tenantId == tenantId &&
             request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)).data.adminUsers;
    }

    function isTenantFieldUser(tenantId) {
      return tenantExists(tenantId) &&
             userProfileExists() &&
             userProfile().role == 'employee' &&
             userProfile().status == 'active' &&
             userProfile().tenantId == tenantId &&
             request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)).data.users;
    }

    function isCustomerUser() {
      return userProfileExists() &&
             userProfile().role == 'customer' &&
             userProfile().status == 'active';
    }

    function customerTenantMatches(tenantId) {
      return isCustomerUser() && userProfile().tenantId == tenantId;
    }

    function isBookingManager(tenantId) {
      return tenantExists(tenantId) &&
             (isSuperAdmin() || isTenantAdmin(tenantId));
    }

    function fieldModeBookingUpdateKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'fieldStatus',
        'fieldStatusUpdatedAt',
        'fieldStartedAt',
        'fieldStartedByUid',
        'fieldChecklist',
        'fieldChecklistSummary',
        'fieldNotes',
        'fieldIssue',
        'completedAt',
        'completedByUid',
        'updatedAt'
      ]);
    }

    function isFieldModeBookingUpdate(tenantId) {
      return isTenantFieldUser(tenantId) && fieldModeBookingUpdateKeysOnly();
    }

    function bookingManagerUpdateKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'date',
        'startTime',
        'endTime',
        'scheduledAt',
        'status',
        'notes',
        'agreedPrice',
        'paymentStatus',
        'paymentStatusUpdatedAt',
        'paymentMethod',
        'amountReceived',
        'receivedAt',
        'paymentNote',
        'paymentStatusUpdatedBy',
        'fieldStatus',
        'fieldStatusUpdatedAt',
        'fieldStartedAt',
        'fieldStartedByUid',
        'fieldChecklist',
        'fieldChecklistSummary',
        'fieldNotes',
        'fieldIssue',
        'completedAt',
        'completedByUid',
        'assignedEmployeeId',
        'updatedAt'
      ]);
    }

    function isSafeSuperAdminRouteUpdate(tenantId) {
      return tenantExists(tenantId) &&
             isSuperAdmin() &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'routeOrder',
               'estimatedTravelTime',
               'distanceFromPrevious',
               'optimizedAt',
               'updatedAt'
             ]);
    }

    function bookingPaymentFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'paymentStatus',
        'paymentStatusUpdatedAt',
        'paymentMethod',
        'amountReceived',
        'receivedAt',
        'paymentNote',
        'paymentStatusUpdatedBy'
      ]);
    }

    function validManualPaymentState() {
      return request.resource.data.paymentStatus in [
               'not_paid',
               'deposit_requested',
               'deposit_paid',
               'final_due',
               'partial',
               'paid_in_full',
               'paid_cash',
               'paid_check',
               'paid_external_app',
               'waived_family_discount',
               'payment_issue'
             ] &&
             request.resource.data.paymentStatusUpdatedBy == request.auth.uid &&
             (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['paymentMethod']) ||
              request.resource.data.paymentMethod in [
                '',
                'cash',
                'check',
                'venmo',
                'cash_app',
                'zelle',
                'facebook_pay',
                'paypal',
                'card',
                'stripe_manual_reference',
                'waived',
                'other'
              ]);
    }

    function isSafeBookingManagerUpdate(tenantId) {
      return isBookingManager(tenantId) &&
             bookingManagerUpdateKeysOnly() &&
             (!bookingPaymentFieldsChanged() || validManualPaymentState());
    }

    function bookingCreateKeysOnly() {
      return request.resource.data.keys().hasOnly([
        'schemaVersion',
        'tenantId',
        'leadId',
        'sourceLeadId',
        'source',
        'customerId',
        'propertyId',
        'customerName',
        'customerSnapshot',
        'propertySnapshot',
        'requestSnapshot',
        'appointmentRequest',
        'employeeId',
        'jobId',
        'date',
        'startTime',
        'endTime',
        'scheduledAt',
        'agreedPrice',
        'status',
        'serviceType',
        'address',
        'notes',
        'createdBy',
        'createdAt',
        'updatedAt'
      ]);
    }

    function isSafeBookingCreate(tenantId) {
      return isBookingManager(tenantId) &&
             bookingCreateKeysOnly() &&
             request.resource.data.status == 'scheduled' &&
             (!('tenantId' in request.resource.data) || request.resource.data.tenantId == tenantId);
    }

    function fieldPhotoMetadataKeysOnly() {
      return request.resource.data.keys().hasAll([
               'id',
               'phase',
               'storagePath',
               'uploadedAt',
               'uploadedByUid',
               'fileName',
               'contentType',
               'sizeBytes'
             ]) &&
             request.resource.data.keys().hasOnly([
               'id',
               'phase',
               'storagePath',
               'uploadedAt',
               'uploadedByUid',
               'fileName',
               'contentType',
               'sizeBytes',
               'clientFileLastModifiedAt'
             ]);
    }

    function validFieldPhotoObjectIdentity(tenantId, bookingId, photoId) {
      let data = request.resource.data;
      let prefix = 'tenants/' + tenantId + '/bookings/' + bookingId + '/field-photos/' + data.phase + '/' + photoId;
      return (data.contentType == 'image/jpeg' && data.storagePath == prefix + '.jpg' && data.fileName == data.phase + '-photo.jpg') ||
             (data.contentType == 'image/png' && data.storagePath == prefix + '.png' && data.fileName == data.phase + '-photo.png') ||
             (data.contentType == 'image/webp' && data.storagePath == prefix + '.webp' && data.fileName == data.phase + '-photo.webp');
    }

    function isValidFieldPhotoMetadataCreate(tenantId, bookingId, photoId) {
      let data = request.resource.data;
      return isTenantFieldUser(tenantId) &&
             fieldPhotoMetadataKeysOnly() &&
             data.id == photoId &&
             data.phase in ['before', 'after'] &&
             data.uploadedByUid == request.auth.uid &&
             data.uploadedAt == request.time &&
             data.sizeBytes is int &&
             data.sizeBytes > 0 &&
             data.sizeBytes <= 10 * 1024 * 1024 &&
             (!('clientFileLastModifiedAt' in data) || data.clientFileLastModifiedAt is timestamp) &&
             validFieldPhotoObjectIdentity(tenantId, bookingId, photoId);
    }

    function isOwnLinkedCustomer(tenantId, customerId) {
      return customerTenantMatches(tenantId) &&
             customerId is string &&
             exists(/databases/$(database)/documents/tenants/$(tenantId)/customers/$(customerId)) &&
             get(/databases/$(database)/documents/tenants/$(tenantId)/customers/$(customerId)).data.authUid == request.auth.uid &&
             (!('isArchived' in get(/databases/$(database)/documents/tenants/$(tenantId)/customers/$(customerId)).data) ||
              get(/databases/$(database)/documents/tenants/$(tenantId)/customers/$(customerId)).data.isArchived != true) &&
             (!('status' in get(/databases/$(database)/documents/tenants/$(tenantId)/customers/$(customerId)).data) ||
              !(get(/databases/$(database)/documents/tenants/$(tenantId)/customers/$(customerId)).data.status in ['archived', 'disabled', 'inactive']));
    }

    function isOwnCustomerRecord(tenantId) {
      return customerTenantMatches(tenantId) && resource.data.authUid == request.auth.uid;
    }

    function customerQuoteRequestKeysOnly() {
      return request.resource.data.keys().hasOnly([
        'schemaVersion',
        'type',
        'source',
        'status',
        'tenantId',
        'customerId',
        'propertyId',
        'createdByAuthUid',
        'formData',
        'estimate',
        'aiAnalysis',
        'booking',
        'customerSnapshot',
        'propertySnapshot',
        'requestSnapshot',
        'review',
        'appointmentRequest',
        'createdAt',
        'updatedAt'
      ]);
    }

    function isOwnCustomerQuoteRequestCreate(tenantId) {
      return customerTenantMatches(tenantId) &&
             request.resource.data.tenantId == tenantId &&
             request.resource.data.createdByAuthUid == request.auth.uid &&
             request.resource.data.type == 'quote_request' &&
             request.resource.data.source == 'customer-portal' &&
             request.resource.data.status == 'new' &&
             request.resource.data.booking == null &&
             isOwnLinkedCustomer(tenantId, request.resource.data.customerId) &&
             customerQuoteRequestKeysOnly();
    }

    function isOwnCustomerQuoteRequestRead(tenantId) {
      return customerTenantMatches(tenantId) &&
             resource.data.tenantId == tenantId &&
             resource.data.createdByAuthUid == request.auth.uid &&
             resource.data.type == 'quote_request' &&
             resource.data.source == 'customer-portal';
    }

    function isOwnCustomerProfileCreate(userId) {
      return isAuthenticated() &&
             request.auth.uid == userId &&
             request.resource.data.keys().hasOnly([
               'email',
               'role',
               'tenantId',
               'displayName',
               'phone',
               'photoURL',
               'status',
               'createdAt',
               'updatedAt'
             ]) &&
             request.resource.data.role == 'customer' &&
             request.resource.data.status == 'active' &&
             request.resource.data.tenantId is string &&
             request.resource.data.tenantId.size() > 0 &&
             tenantExists(request.resource.data.tenantId);
    }

    function isSafeOwnProfileUpdate(userId) {
      return isAuthenticated() &&
             request.auth.uid == userId &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'displayName',
               'phone',
               'photoURL',
               'updatedAt'
             ]);
    }

    function businessSettingsKeysOnly() {
      return request.resource.data.businessSettings.keys().hasOnly([
               'businessName',
               'businessPhone',
               'businessEmail',
               'serviceArea',
               'businessAddress',
               'websiteUrl',
               'facebookUrl',
               'defaultServiceNotes',
               'availability'
             ]) &&
             request.resource.data.businessSettings.availability.keys().hasOnly(['availableDays']) &&
             request.resource.data.businessSettings.availability.availableDays is list;
    }

    function isSafeBusinessSettingsUpdate(tenantId) {
      return isTenantAdmin(tenantId) &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'businessSettings',
               'updatedAt',
               'updatedByUid'
             ]) &&
             businessSettingsKeysOnly() &&
             (!('updatedByUid' in request.resource.data) || request.resource.data.updatedByUid == request.auth.uid);
    }

    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow create: if isSuperAdmin() && tenantId != 'DEFAULT';
      allow update: if isSuperAdmin() || isSafeBusinessSettingsUpdate(tenantId);
      allow delete: if isSuperAdmin();

      match /leads/{leadId} {
        allow read: if tenantExists(tenantId) &&
                       (isSuperAdmin() || isTenantAdmin(tenantId) || isOwnCustomerQuoteRequestRead(tenantId));
        allow create: if tenantExists(tenantId) &&
                         (isSuperAdmin() || isTenantAdmin(tenantId) || isOwnCustomerQuoteRequestCreate(tenantId));
        allow update, delete: if tenantExists(tenantId) &&
                                 (isSuperAdmin() || isTenantAdmin(tenantId));
      }

      match /bookings/{bookingId} {
        allow read: if isBookingManager(tenantId) || isTenantFieldUser(tenantId);
        allow create: if isSafeBookingCreate(tenantId);
        allow update: if isSafeBookingManagerUpdate(tenantId) ||
                         isFieldModeBookingUpdate(tenantId) ||
                         isSafeSuperAdminRouteUpdate(tenantId);
        allow delete: if isBookingManager(tenantId);

        match /fieldPhotos/{photoId} {
          allow read: if isBookingManager(tenantId) || isTenantFieldUser(tenantId);
          allow create: if isValidFieldPhotoMetadataCreate(tenantId, bookingId, photoId);
          allow update, delete: if false;
        }
      }

      match /customers/{customerId} {
        allow read: if tenantExists(tenantId) &&
                       (isSuperAdmin() || isTenantAdmin(tenantId) || isOwnCustomerRecord(tenantId));
        allow create, update, delete: if tenantExists(tenantId) &&
                                        (isSuperAdmin() || isTenantAdmin(tenantId));
      }

      match /payments/{paymentId} {
        allow read: if tenantExists(tenantId) &&
                       (isSuperAdmin() || isTenantAdmin(tenantId));
        allow create, update, delete: if false;
      }

      // Mounted super-admin compatibility paths.
      match /employees/{employeeId} {
        allow read, create, update, delete: if tenantExists(tenantId) && isSuperAdmin();
      }

      match /branding/{brandingId} {
        allow read, create, update, delete: if tenantExists(tenantId) && isSuperAdmin();
      }

      match /insurance/{insuranceId} {
        allow read, create, update, delete: if tenantExists(tenantId) && isSuperAdmin();
      }

      // Unmounted or unsafe legacy paths remain client-denied. Admin SDK runtimes bypass rules.
      match /quotes/{quoteId} {
        allow read, write: if false;
      }

      match /jobs/{jobId} {
        allow read, write: if false;
      }

      match /properties/{propertyId} {
        allow read, write: if false;
      }

      match /photos/{photoId} {
        allow read, write: if false;
      }

      match /appointments/{appointmentId} {
        allow read, write: if false;
      }

      match /ai_learning_data/{learningId} {
        allow read, write: if false;
      }

      match /ai_models/{modelId} {
        allow read, write: if false;
      }

      match /customer_reviews/{reviewId} {
        allow read, write: if false;
      }

      match /white_label_domains/{domainId} {
        allow read, write: if false;
      }

      match /upsell_offers/{offerId} {
        allow read, write: if false;
      }

      match /upsell_impressions/{impressionId} {
        allow read, write: if false;
      }

      match /upsell_acceptances/{acceptanceId} {
        allow read, write: if false;
      }

      match /time_clock/{clockId} {
        allow read, write: if false;
      }

      match /{unprovenPath=**} {
        allow read, write: if false;
      }
    }

    match /tenant_usage/{tenantId} {
      allow read, create, update, delete: if isSuperAdmin() && tenantId != 'DEFAULT';
    }

    match /ai_usage/{tenantId} {
      allow read, create, update, delete: if isSuperAdmin() && tenantId != 'DEFAULT';
    }

    match /ai_credit_history/{historyId} {
      allow read, create: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /tenant_billing/{billingId} {
      allow read: if isSuperAdmin() || isTenantAdmin(resource.data.tenantId);
      allow create, update, delete: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isOwnCustomerProfileCreate(userId);
      allow update: if isSafeOwnProfileUpdate(userId);
      allow delete: if false;
    }

    match /{unprovenGlobalPath=**} {
      allow read, write: if false;
    }
  }
}
