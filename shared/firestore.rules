rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // TEMPORARY: Allow all authenticated users for testing customer CRUD
    // This will be reverted after testing is complete
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin';
    }

    function authenticatedUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasAuthenticatedUserProfile() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isCustomerUser() {
      return hasAuthenticatedUserProfile() &&
             authenticatedUserProfile().role == 'customer' &&
             authenticatedUserProfile().status == 'active';
    }

    function isEmployeeUser() {
      return hasAuthenticatedUserProfile() &&
             authenticatedUserProfile().role == 'employee';
    }

    // Preserve legacy access for recognized non-employee roles only.
    // Remaining temporary rules still require module-by-module hardening.
    function isLegacyBroadAccessUser() {
      return hasAuthenticatedUserProfile() &&
             !isEmployeeUser() &&
             (authenticatedUserProfile().role == 'customer' ||
              authenticatedUserProfile().role == 'admin' ||
              authenticatedUserProfile().role == 'super-admin');
    }

    function userTenantMatches(tenantId) {
      return hasAuthenticatedUserProfile() &&
             authenticatedUserProfile().tenantId == tenantId;
    }
    
    function isTenantAdmin(tenantId) {
      return hasAuthenticatedUserProfile() &&
             authenticatedUserProfile().role == 'admin' &&
             authenticatedUserProfile().tenantId == tenantId &&
             (!('status' in authenticatedUserProfile()) || authenticatedUserProfile().status == 'active') &&
             request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)).data.adminUsers;
    }
    
    function isTenantUser(tenantId) {
      return isAuthenticated() && 
             request.auth.uid in get(/databases/$(database)/documents/tenants/$(tenantId)).data.users;
    }

    function isTenantFieldUser(tenantId) {
      return hasAuthenticatedUserProfile() &&
             authenticatedUserProfile().role == 'employee' &&
             authenticatedUserProfile().status == 'active' &&
             authenticatedUserProfile().tenantId == tenantId &&
             isTenantUser(tenantId);
    }
    
    function hasTenantAccess(tenantId) {
      return isTenantAdmin(tenantId) || isTenantUser(tenantId);
    }

    function fieldModeBookingUpdateKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'fieldStatus',
        'fieldStatusUpdatedAt',
        'fieldStartedAt',
        'fieldStartedByUid',
        'fieldChecklist',
        'fieldChecklistSummary',
        'fieldNotes',
        'fieldIssue',
        'completedAt',
        'completedByUid',
        'updatedAt'
      ]);
    }

    function isFieldModeBookingUpdate(tenantId) {
      return isTenantFieldUser(tenantId) && fieldModeBookingUpdateKeysOnly();
    }

    function fieldPhotoMetadataKeysOnly() {
      return request.resource.data.keys().hasAll([
               'id',
               'phase',
               'storagePath',
               'uploadedAt',
               'uploadedByUid',
               'fileName',
               'contentType',
               'sizeBytes'
             ]) &&
             request.resource.data.keys().hasOnly([
               'id',
               'phase',
               'storagePath',
               'uploadedAt',
               'uploadedByUid',
               'fileName',
               'contentType',
               'sizeBytes',
               'clientFileLastModifiedAt'
             ]);
    }

    function validFieldPhotoObjectIdentity(tenantId, bookingId, photoId) {
      let data = request.resource.data;
      let prefix = 'tenants/' + tenantId + '/bookings/' + bookingId + '/field-photos/' + data.phase + '/' + photoId;
      return (data.contentType == 'image/jpeg' && data.storagePath == prefix + '.jpg' && data.fileName == data.phase + '-photo.jpg') ||
             (data.contentType == 'image/png' && data.storagePath == prefix + '.png' && data.fileName == data.phase + '-photo.png') ||
             (data.contentType == 'image/webp' && data.storagePath == prefix + '.webp' && data.fileName == data.phase + '-photo.webp');
    }

    function isValidFieldPhotoMetadataCreate(tenantId, bookingId, photoId) {
      let data = request.resource.data;
      return isTenantFieldUser(tenantId) &&
             fieldPhotoMetadataKeysOnly() &&
             data.id == photoId &&
             data.phase in ['before', 'after'] &&
             data.uploadedByUid == request.auth.uid &&
             data.uploadedAt == request.time &&
             data.sizeBytes is int &&
             data.sizeBytes > 0 &&
             data.sizeBytes <= 10 * 1024 * 1024 &&
             (!('clientFileLastModifiedAt' in data) || data.clientFileLastModifiedAt is timestamp) &&
             validFieldPhotoObjectIdentity(tenantId, bookingId, photoId);
    }

    function isOwnLinkedCustomer(tenantId, customerId) {
      let customer = get(/databases/$(database)/documents/tenants/$(tenantId)/customers/$(customerId)).data;
      return isCustomerUser() &&
             userTenantMatches(tenantId) &&
             customerId is string &&
             exists(/databases/$(database)/documents/tenants/$(tenantId)/customers/$(customerId)) &&
             customer.authUid == request.auth.uid &&
             (!('isArchived' in customer) || customer.isArchived != true) &&
             (!('status' in customer) || !(customer.status in ['archived', 'disabled', 'inactive']));
    }

    function isOwnCustomerRecord(tenantId) {
      return isCustomerUser() &&
             userTenantMatches(tenantId) &&
             resource.data.authUid == request.auth.uid;
    }

    function customerQuoteRequestKeysOnly() {
      return request.resource.data.keys().hasOnly([
        'schemaVersion',
        'type',
        'source',
        'status',
        'tenantId',
        'customerId',
        'propertyId',
        'createdByAuthUid',
        'formData',
        'estimate',
        'aiAnalysis',
        'booking',
        'customerSnapshot',
        'propertySnapshot',
        'requestSnapshot',
        'review',
        'appointmentRequest',
        'createdAt',
        'updatedAt'
      ]);
    }

    function isOwnCustomerQuoteRequestCreate(tenantId) {
      return isCustomerUser() &&
             userTenantMatches(tenantId) &&
             request.resource.data.tenantId == tenantId &&
             request.resource.data.createdByAuthUid == request.auth.uid &&
             request.resource.data.type == 'quote_request' &&
             request.resource.data.source == 'customer-portal' &&
             request.resource.data.status == 'new' &&
             request.resource.data.booking == null &&
             isOwnLinkedCustomer(tenantId, request.resource.data.customerId) &&
             customerQuoteRequestKeysOnly();
    }

    function isOwnCustomerQuoteRequestRead(tenantId) {
      return isCustomerUser() &&
             userTenantMatches(tenantId) &&
             resource.data.tenantId == tenantId &&
             resource.data.createdByAuthUid == request.auth.uid &&
             resource.data.type == 'quote_request' &&
             resource.data.source == 'customer-portal';
    }

    function isOwnCustomerProfileCreate(userId) {
      return isAuthenticated() &&
             request.auth.uid == userId &&
             request.resource.data.keys().hasOnly([
               'email',
               'role',
               'tenantId',
               'displayName',
               'phone',
               'photoURL',
               'status',
               'createdAt',
               'updatedAt'
             ]) &&
             request.resource.data.role == 'customer' &&
             request.resource.data.status == 'active' &&
             request.resource.data.tenantId is string &&
             request.resource.data.tenantId.size() > 0 &&
             exists(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId));
    }

    function isSafeOwnProfileUpdate(userId) {
      return isAuthenticated() &&
             request.auth.uid == userId &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'displayName',
               'phone',
               'photoURL',
               'updatedAt'
             ]);
    }
    
    // Tenants collection - allow create for testing, will restrict later
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || isTenantAdmin(tenantId) || (isTenantUser(tenantId) && !isEmployeeUser());
      allow create: if isLegacyBroadAccessUser(); // Temporary legacy access; employees are explicitly denied
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin();
    }
    
    // Tenant usage - allow create for testing, will restrict later
    match /tenant_usage/{tenantId} {
      allow read, write: if isLegacyBroadAccessUser(); // Temporary legacy access; employees are explicitly denied
    }
    
    // Tenant billing - only tenant admin can read
    match /tenant_billing/{billingId} {
      allow read: if isTenantAdmin(resource.data.tenantId);
      allow write: if false; // Only system can write via Stripe webhooks
    }
    
    // Leads - isolated by tenant
    match /tenants/{tenantId}/leads/{leadId} {
      allow read: if isSuperAdmin() || isTenantAdmin(tenantId) || isOwnCustomerQuoteRequestRead(tenantId);
      allow create: if isSuperAdmin() || isTenantAdmin(tenantId) || isOwnCustomerQuoteRequestCreate(tenantId);
      allow update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // Quotes - isolated by tenant
    match /tenants/{tenantId}/quotes/{quoteId} {
      allow read: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow create: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // Bookings - isolated by tenant
    match /tenants/{tenantId}/bookings/{bookingId} {
      allow read: if isSuperAdmin() || isTenantAdmin(tenantId) || isTenantFieldUser(tenantId);
      allow create: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId) || isFieldModeBookingUpdate(tenantId);
      allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);

      match /fieldPhotos/{photoId} {
        allow read: if isSuperAdmin() || isTenantAdmin(tenantId) || isTenantFieldUser(tenantId);
        allow create: if isValidFieldPhotoMetadataCreate(tenantId, bookingId, photoId);
        allow update, delete: if false;
      }
    }
    
    // Payments - isolated by tenant
    match /tenants/{tenantId}/payments/{paymentId} {
      allow read: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow create: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow update: if isSuperAdmin() || false; // Only system can update via Stripe webhooks
      allow delete: if isSuperAdmin() || false;
    }
    
    // Jobs - isolated by tenant (for dataset collection)
    match /tenants/{tenantId}/jobs/{jobId} {
      allow read: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow create: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // Properties - isolated by tenant (for dataset collection)
    match /tenants/{tenantId}/properties/{propertyId} {
      allow read: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow create: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // Photos - isolated by tenant (before/after photos for dataset)
    match /tenants/{tenantId}/photos/{photoId} {
      allow read: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow create: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // AI Learning Data - isolated by tenant (for ML training)
    match /tenants/{tenantId}/ai_learning_data/{learningId} {
      allow read: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow create: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // Customer Reviews - isolated by tenant
    match /tenants/{tenantId}/customer_reviews/{reviewId} {
      allow read: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow create: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // Employees - isolated by tenant
    match /tenants/{tenantId}/employees/{employeeId} {
      allow read: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow create: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // Customers - isolated by tenant (CRM)
    match /tenants/{tenantId}/customers/{customerId} {
      allow read: if isSuperAdmin() || isTenantAdmin(tenantId) || isOwnCustomerRecord(tenantId);
      allow create, update, delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // Appointments - isolated by tenant (scheduling)
    match /tenants/{tenantId}/appointments/{appointmentId} {
      allow read: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow create: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // White Label Domains - isolated by tenant
    match /tenants/{tenantId}/white_label_domains/{domainId} {
      allow read: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow create: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // Upsell Offers - isolated by tenant
    match /tenants/{tenantId}/upsell_offers/{offerId} {
      allow read: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow create: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow update: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // Upsell Impressions - isolated by tenant (analytics)
    match /tenants/{tenantId}/upsell_impressions/{impressionId} {
      allow read: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow create: if isSuperAdmin() || false; // System only
      allow update: if isSuperAdmin() || false;
      allow delete: if isSuperAdmin() || false;
    }
    
    // Upsell Acceptances - isolated by tenant (analytics)
    match /tenants/{tenantId}/upsell_acceptances/{acceptanceId} {
      allow read: if isSuperAdmin() || isTenantAdmin(tenantId);
      allow create: if isSuperAdmin() || false; // System only
      allow update: if isSuperAdmin() || false;
      allow delete: if isSuperAdmin() || false;
    }
    
    // Time Clock - isolated by tenant (employee tracking)
    match /tenants/{tenantId}/time_clock/{clockId} {
      allow read: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow create: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow update: if isSuperAdmin() || (hasTenantAccess(tenantId) && !isEmployeeUser());
      allow delete: if isSuperAdmin() || isTenantAdmin(tenantId);
    }
    
    // Users collection - for user management
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isOwnCustomerProfileCreate(userId);
      allow update: if isSafeOwnProfileUpdate(userId);
      allow delete: if false;
    }
  }
}
